# LLM credentials — point at LiteLLM or any OpenAI-compatible endpoint
AGENT_MODEL_API_KEY=<your-api-key>
AGENT_MODEL_BASE_URL=https://litellm.dev.example.com
AGENT_MODEL=claude-sonnet-4-5-20250929

# Demo dataset selection (used by startup_demo.sh to build the database)
# Options: hormuz, caribbean, ukraine, south_china_sea (must match a directory in mcp_apps/mcp_query_duckdb/data/datasets/)
DEMO_DATASET=hormuz

# Demo dataset reproducibility - seed for random data generation (0 = non-repeatable, any number = repeatable)
DEMO_REPEATABLE_SEED=17

# Langfuse (auto-initialized with defaults below, change in production)
# LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-helix-a2a
# LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-helix-a2a
